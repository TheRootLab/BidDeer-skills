{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://biddeer.local/schemas/proposal-point-checker/candidates.schema.json",
  "title": "proposal-point-checker candidates.json",
  "description": "Candidate evidence packages emitted by the future retrieve step. This schema mirrors ChecklistItem, EvidencePackage, CandidateEvidence, UserFacingLocator, and ImageObject without page positioning semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packages"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "proposal-point-checker.candidates.v0.1"
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/evidencePackage"
      }
    }
  },
  "definitions": {
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "itemId",
        "name",
        "requirement",
        "note"
      ],
      "properties": {
        "itemId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "requirement": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "evidencePackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "candidates"
      ],
      "properties": {
        "item": {
          "$ref": "#/definitions/checklistItem"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/candidateEvidence"
          }
        }
      }
    },
    "candidateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blockIndex",
        "userLocator",
        "matchedKeywords",
        "exactText",
        "preContext",
        "postContext",
        "nearbyImages",
        "rowIndex"
      ],
      "properties": {
        "blockIndex": {
          "type": "integer",
          "minimum": 0
        },
        "userLocator": {
          "$ref": "#/definitions/userLocator"
        },
        "matchedKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exactText": {
          "type": "string"
        },
        "preContext": {
          "type": "string"
        },
        "postContext": {
          "type": "string"
        },
        "nearbyImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/imageObject"
          }
        },
        "rowIndex": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "userLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceDocName",
        "headingPath",
        "nearestHeading",
        "nearbyText",
        "locatorHint",
        "evidenceType"
      ],
      "properties": {
        "sourceDocName": {
          "type": "string"
        },
        "headingPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nearestHeading": {
          "type": [
            "string",
            "null"
          ]
        },
        "nearbyText": {
          "type": "string"
        },
        "locatorHint": {
          "type": "string"
        },
        "evidenceType": {
          "type": "string"
        }
      }
    },
    "imageObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imageId",
        "anchorBlockIndex",
        "anchorParagraphIndex",
        "nearbyText",
        "relationshipId",
        "contentRecognized",
        "reason"
      ],
      "properties": {
        "imageId": {
          "type": "string"
        },
        "anchorBlockIndex": {
          "type": "integer",
          "minimum": 0
        },
        "anchorParagraphIndex": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "nearbyText": {
          "type": "string"
        },
        "relationshipId": {
          "type": "string"
        },
        "contentRecognized": {
          "type": "boolean",
          "const": false
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
